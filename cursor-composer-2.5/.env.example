# Required — use: openssl rand -base64 48
SESSION_SECRET=

# production | development
NODE_ENV=development

# Server
PORT=3000

# SQLite database file path (directory must exist and be writable)
DATABASE_PATH=./data/notes.db

# Bind host (use 127.0.0.1 behind a reverse proxy in production)
HOST=127.0.0.1

# Set to true when running behind HTTPS-terminating reverse proxy
TRUST_PROXY=false
