# Environment configuration - COPY this to .env and fill in real values
# NEVER commit the real .env file

# App
NODE_ENV=production
PORT=3000

# Session secret - MUST be a long random string (min 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS_LONG_xxxxxxxxxxxxx

# Database
DB_PATH=./data/notes.db

# Session store (optional - uses memory if not set)
# REDIS_URL=redis://localhost:6379

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Trusted proxy count (set to 1 if behind a single reverse proxy like nginx)
TRUST_PROXY=1
