{
  "name": "secure-notes-app",
  "version": "1.0.0",
  "description": "Production-ready, secure Node.js notes application",
  "main": "src/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node --experimental-sqlite src/server.js",
    "dev": "nodemon --exec \"node --experimental-sqlite src/server.js\"",
    "test": "node --experimental-sqlite node_modules/jest/bin/jest.js --runInBand",
    "test:security": "node --experimental-sqlite node_modules/jest/bin/jest.js --runInBand --testPathPattern=security"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "connect-redis": "^7.1.1",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.18.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "morgan": "^1.10.0",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  }
}
