# Copy to .env for local development (never commit .env)

NODE_ENV=development
PORT=3000

# Required in production: random string, >= 32 characters (e.g. openssl rand -base64 48)
SESSION_SECRET=

# Set to 1 when behind a reverse proxy (nginx, Cloudflare, etc.) so secure cookies and IP limits work
TRUST_PROXY=0

# SQLite paths (directories are created on startup)
DATABASE_PATH=./data/notes.db
SESSION_FILES_DIR=./data/sessions
