# Copy this file to ".env" and fill in real values. NEVER commit your real .env.

# Environment: "development" or "production".
# In production the app enforces HTTPS-only cookies and HSTS.
NODE_ENV=development

# Port and bind address.
PORT=3000
# Use 127.0.0.1 to keep it local; set 0.0.0.0 only behind a trusted proxy.
HOST=127.0.0.1

# REQUIRED. High-entropy secret used to sign session cookies.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Path to the SQLite database file.
DATABASE_PATH=./data/notes.db

# Number of reverse proxies in front of the app (0 = none/direct).
# Set to 1 if you run behind nginx / a load balancer / a PaaS router so that
# secure cookies and rate-limit client IPs are handled correctly.
TRUST_PROXY=0
