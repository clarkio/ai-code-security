# Copy this file to .env and fill in real values. Never commit .env.

# Required: at least 64 random hex characters (e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`)
SESSION_SECRET=

# Set to "production" when deploying. Locally: "development".
NODE_ENV=production

# Port to listen on.
PORT=3000

# Bind address. Use 127.0.0.1 if behind a reverse proxy on the same host.
HOST=127.0.0.1

# Set to "true" only if behind a trusted reverse proxy (e.g. nginx, AWS ALB)
# that terminates TLS and sets X-Forwarded-* headers. Required for secure
# cookies + correct client-IP rate limiting in that topology.
TRUST_PROXY=false

# Path to the SQLite database file. Directory must be writable, not web-served.
DATABASE_PATH=./data/app.sqlite
